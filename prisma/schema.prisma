generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model news {
  id          Int      @id @default(autoincrement())
  title       String
  source_url  String
  source_name String
  image_url   String?
  tags        String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  is_pinned   Boolean  @default(false)
}
