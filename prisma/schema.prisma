generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model app_user {
  id                                     Int                    @id @default(autoincrement())
  email                                  String                 @unique
  password_hash                          String
  role                                   user_role_enum
  status                                 user_status_enum       @default(PENDING)
  created_at                             DateTime               @default(now()) @db.Timestamptz(6)
  points                                 Int                    @default(0)
  first_name                             String?
  last_name                              String?
  city                                   String?
  organization_id                        Int?
  admin_profile                          admin_profile?
  organization                           organization_profile?  @relation("OrganizationMembers", fields: [organization_id], references: [id])
  reviewed_requests                      approval_request[]     @relation("reviewed_requests")
  submitted_requests                     approval_request[]     @relation("submitted_requests")
  news                                   news[]
  organization_profile                   organization_profile?  @relation("OrganizationOwner")
  password_reset_token                   password_reset_token[]
  points_transaction                     points_transaction[]
  project_registration                   project_registration[]
  reward_redemption                      reward_redemption[]
  volunteer_profile                      volunteer_profile?
  ticket                                 ticket[]
  warnings_warnings_created_byToapp_user warnings[]             @relation("warnings_created_byToapp_user")
  warnings_warnings_user_idToapp_user    warnings[]             @relation("warnings_user_idToapp_user")
  donation                               donation[]
  organization_membership_request        organization_membership_request[]
}

model volunteer_profile {
  id                   Int                    @id @default(autoincrement())
  user_id              Int                    @unique
  display_name         String                 @unique
  phone                String
  bio                  String
  skills_text          String?
  rating               Decimal?               @db.Decimal(3, 2)
  is_verified          Boolean                @default(false)
  avatar_url           String?
  docs_url             String?
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  fundraising_campaign fundraising_campaign[]
  task_assignment      task_assignment[]
  tickets              ticket[]
  app_user             app_user               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_volunteer_profile_user")
}

model organization_profile {
  id                    Int                      @id @default(autoincrement())
  user_id               Int                      @unique
  name                  String
  edrpou                String                   @unique
  description           String?
  verification_status   verification_status_enum @default(PENDING)
  official_docs_url     String?
  contact_phone         String?
  contact_email         String?
  city                  String?
  logo_url              String?
  location_id           Int?
  created_at            DateTime                 @default(now()) @db.Timestamptz(6)
  mission               String
  members               app_user[]               @relation("OrganizationMembers")
  fundraising_campaign  fundraising_campaign[]
  news                  news[]
  organization_category organization_category[]
  location              location?                @relation(fields: [location_id], references: [id], onUpdate: NoAction, map: "fk_organization_profile_location")
  app_user              app_user                 @relation("OrganizationOwner", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_organization_profile_user")
  project               project[]
  report                report[]
  membership_requests   organization_membership_request[]

  @@index([location_id], map: "idx_organization_profile_location_id")
}

model organization_membership_request {
  id              Int                                            @id @default(autoincrement())
  organization_id Int
  user_id         Int
  direction       organization_membership_request_direction_enum @default(REQUEST)
  status          organization_membership_request_status_enum    @default(PENDING)
  created_at      DateTime                                       @default(now()) @db.Timestamptz(6)
  reviewed_at     DateTime?                                      @db.Timestamptz(6)
  organization    organization_profile                        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_org_membership_request_org")
  user            app_user                                    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_org_membership_request_user")

  @@unique([organization_id, user_id], map: "uq_org_membership_request")
  @@index([organization_id], map: "idx_org_membership_request_org_id")
  @@index([user_id], map: "idx_org_membership_request_user_id")
}

model admin_profile {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  full_name      String
  is_super_admin Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  app_user       app_user @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_admin_profile_user")
}

model project {
  id                      Int                    @id @default(autoincrement())
  organization_profile_id Int
  title                   String
  description             String
  status                  project_status_enum    @default(DRAFT)
  starts_at               DateTime?              @db.Timestamptz(6)
  ends_at                 DateTime?              @db.Timestamptz(6)
  created_at              DateTime               @default(now()) @db.Timestamptz(6)
  updated_at              DateTime               @default(now()) @db.Timestamptz(6)
  main_content            String?
  what_volunteers_will_do String?
  why_its_important       String?
  time                    String?
  application_deadline    DateTime?              @db.Timestamptz(6)
  location_id             Int?
  category_id             Int?
  partners                String?
  image_url               String?
  organization_profile    organization_profile   @relation(fields: [organization_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_organization")
  location                location?              @relation(fields: [location_id], references: [id], onUpdate: NoAction, map: "fk_project_location")
  category                category?              @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "fk_project_category")
  project_registration    project_registration[]
  report                  report[]
  task                    task[]
  project_category        project_category[]

  @@index([organization_profile_id], map: "idx_project_organization_profile_id")
  @@index([location_id], map: "idx_project_location_id")
  @@index([category_id], map: "idx_project_category_id")
}

model project_registration {
  id         Int      @id @default(autoincrement())
  project_id Int
  user_id    Int
  status     String   @default("PENDING")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  project    project  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  app_user   app_user @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id], map: "uq_project_registration")
  @@index([project_id])
  @@index([user_id])
}

model task {
  id                 Int                  @id @default(autoincrement())
  project_id         Int
  ticket_id          Int?
  title              String
  description        String
  status             task_status_enum     @default(OPEN)
  difficulty         task_difficulty_enum @default(MEDIUM)
  points_reward_base Int
  location_id        Int?
  deadline           DateTime?            @db.Timestamptz(6)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  location           location?            @relation(fields: [location_id], references: [id], onUpdate: NoAction, map: "fk_task_location")
  project            project              @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_project")
  ticket             ticket?              @relation(fields: [ticket_id], references: [id], onUpdate: NoAction, map: "fk_task_ticket")
  task_assignment    task_assignment[]
  task_category      task_category[]

  @@index([location_id], map: "idx_task_location_id")
  @@index([project_id], map: "idx_task_project_id")
  @@index([ticket_id], map: "idx_task_ticket_id")
}

model category {
  id                    Int                     @id @default(autoincrement())
  name                  String
  slug                  String                  @unique
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  news_category         news_category[]
  organization_category organization_category[]
  project               project[]
  task_category         task_category[]
  fundraising_category  fundraising_category[]
  project_category      project_category[]
}

model task_category {
  id          Int      @id @default(autoincrement())
  task_id     Int
  category_id Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_category_category")
  task        task     @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_category_task")

  @@unique([task_id, category_id], map: "uq_task_category")
}
model fundraising_category {
  id          Int                  @id @default(autoincrement())
  campaign_id Int
  category_id Int
  created_at  DateTime             @default(now()) @db.Timestamptz(6)
  category    category             @relation(fields: [category_id], references: [id], onDelete: Cascade)
  fundraising_campaign fundraising_campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, category_id])
}
model project_category {
  id          Int      @id @default(autoincrement())
  project_id  Int
  category_id Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_category_category")
  project     project  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_project_category_project")

  @@unique([project_id, category_id], map: "uq_project_category")
}

model fundraising_campaign {
  id                      Int                              @id @default(autoincrement())
  organization_profile_id Int?
  volunteer_profile_id    Int?
  title                   String
  description             String
  main_content            String
  goal_amount             Decimal                          @db.Decimal(12, 2)
  current_amount          Decimal                          @default(0) @db.Decimal(12, 2)
  status                  fundraising_campaign_status_enum @default(DRAFT)
  start_at                DateTime?                        @db.Timestamptz(6)
  end_at                  DateTime?                        @db.Timestamptz(6)
  created_at              DateTime                         @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                         @default(now()) @db.Timestamptz(6)
  bank_link               String?
  image_url               String?
  jar_link                String?
  jar_id                  String?
  mono_token              String?
  fundraising_category    fundraising_category[]
  donation                donation[]
  organization_profile    organization_profile?            @relation(fields: [organization_profile_id], references: [id], onUpdate: NoAction, map: "fk_fundraising_campaign_organization")
  volunteer_profile       volunteer_profile?               @relation(fields: [volunteer_profile_id], references: [id], onUpdate: NoAction, map: "fk_fundraising_campaign_volunteer")

  @@index([organization_profile_id], map: "idx_fundraising_campaign_organization_profile_id")
  @@index([volunteer_profile_id], map: "idx_fundraising_campaign_volunteer_profile_id")
}

model donation {
  id                   Int                  @id @default(autoincrement())
  amount               Float
  donor_name           String?
  message              String?
  user_id              Int?
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  campaign_id          Int
  fundraising_campaign fundraising_campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_donation_campaign")
  app_user             app_user?            @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "fk_donation_user")

  @@index([campaign_id], map: "idx_donation_campaign_id")
  @@index([user_id])
}

model news {
  id              Int                   @id @default(autoincrement())
  title           String
  image_url       String?
  created_at      DateTime              @default(now()) @db.Timestamptz(6)
  is_pinned       Boolean               @default(false)
  description     String
  main_content    String
  created_by      Int?
  organization_id Int?
  app_user        app_user?             @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_news_created_by")
  organization    organization_profile? @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  news_category   news_category[]

  @@index([created_by], map: "idx_news_created_by")
  @@index([organization_id])
}

model news_category {
  id          Int      @id @default(autoincrement())
  news_id     Int
  category_id Int
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  category    category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_news_category_category")
  news        news     @relation(fields: [news_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_news_category_news")

  @@unique([news_id, category_id], map: "uq_news_category")
}

model location {
  id                   Int                    @id @default(autoincrement())
  lat                  Decimal?               @db.Decimal(9, 6)
  lng                  Decimal?               @db.Decimal(9, 6)
  address              String
  region               String
  city                 String
  organization_profile organization_profile[]
  task                 task[]
  ticket               ticket[]
  project              project[]
}

model approval_request {
  id               Int                          @id @default(autoincrement())
  type             approval_request_type_enum
  status           approval_request_status_enum @default(PENDING)
  entity_id        Int
  submitted_by     Int
  reviewed_by      Int?
  rejection_reason String?
  created_at       DateTime                     @default(now()) @db.Timestamptz(6)
  reviewed_at      DateTime?                    @db.Timestamptz(6)
  reviewer         app_user?                    @relation("reviewed_requests", fields: [reviewed_by], references: [id], onUpdate: NoAction, map: "fk_approval_request_reviewer")
  submitter        app_user                     @relation("submitted_requests", fields: [submitted_by], references: [id], onUpdate: NoAction, map: "fk_approval_request_submitter")

  @@index([submitted_by], map: "idx_approval_request_submitted_by")
  @@index([reviewed_by], map: "idx_approval_request_reviewed_by")
}

model reward {
  id                Int                 @id @default(autoincrement())
  title             String
  description       String
  cost_points       Int
  stock             Int
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  reward_redemption reward_redemption[]
}

model reward_redemption {
  id         Int      @id @default(autoincrement())
  reward_id  Int
  user_id    Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  reward     reward   @relation(fields: [reward_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reward_redemption_reward")
  app_user   app_user @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reward_redemption_user")
}

model points_transaction {
  id                 Int                          @id @default(autoincrement())
  user_id            Int
  task_assignment_id Int?
  amount             Int
  type               points_transaction_type_enum
  reason             String
  created_at         DateTime                     @default(now()) @db.Timestamptz(6)
  task_assignment    task_assignment?             @relation(fields: [task_assignment_id], references: [id], onUpdate: NoAction, map: "fk_points_transaction_task_assignment")
  app_user           app_user                     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_points_transaction_user")
}

model task_assignment {
  id                   Int                         @id @default(autoincrement())
  task_id              Int
  volunteer_profile_id Int
  status               task_assignment_status_enum @default(ASSIGNED)
  assigned_at          DateTime                    @default(now()) @db.Timestamptz(6)
  accepted_at          DateTime?                   @db.Timestamptz(6)
  completed_at         DateTime?                   @db.Timestamptz(6)
  created_at           DateTime                    @default(now()) @db.Timestamptz(6)
  requester_confirmed  Boolean                     @default(false)
  comment              String?
  points_transaction   points_transaction[]
  task                 task                        @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_assignment_task")
  volunteer_profile    volunteer_profile           @relation(fields: [volunteer_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_task_assignment_volunteer_profile")
}

model ticket {
  id                   Int                  @id @default(autoincrement())
  volunteer_profile_id Int?
  title                String
  description          String
  status               ticket_status_enum   @default(OPEN)
  priority             ticket_priority_enum @default(MEDIUM)
  location_id          Int?
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  closed_at            DateTime?            @db.Timestamptz(6)
  task                 task[]
  user_id              Int?
  app_user             app_user?            @relation(fields: [user_id], references: [id])
  location             location?            @relation(fields: [location_id], references: [id], onUpdate: NoAction, map: "fk_ticket_location")
  volunteer_profile    volunteer_profile?    @relation(fields: [volunteer_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ticket_volunteer_profile")
}

model organization_category {
  id                   Int                  @id @default(autoincrement())
  organization_id      Int
  category_id          Int
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  category             category             @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_organization_category_category")
  organization_profile organization_profile @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_organization_category_org")

  @@unique([organization_id, category_id], map: "uq_organization_category")
}

model warnings {
  id                                     Int                   @id @default(autoincrement())
  user_id                                Int
  created_by                             Int
  reason                                 String
  description                            String
  status                                 warning_status_enum   @default(ACTIVE)
  severity                               warning_severity_enum @default(MEDIUM)
  issued_at                              DateTime              @default(now()) @db.Timestamptz(6)
  expires_at                             DateTime?             @db.Timestamptz(6)
  resolved_at                            DateTime?             @db.Timestamptz(6)
  related_entity_type                    String?
  related_entity_id                      Int?
  created_at                             DateTime              @default(now()) @db.Timestamptz(6)
  app_user_warnings_created_byToapp_user app_user              @relation("warnings_created_byToapp_user", fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_warnings_created_by")
  app_user_warnings_user_idToapp_user    app_user              @relation("warnings_user_idToapp_user", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_warnings_user")
}

model password_reset_token {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  app_user   app_user @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_token_user")
}

model report {
  id                      Int                  @id @default(autoincrement())
  organization_profile_id Int
  project_id              Int?
  title                   String
  type                    report_type_enum
  file_url                String
  published_at            DateTime             @db.Timestamptz(6)
  created_at              DateTime             @default(now()) @db.Timestamptz(6)
  updated_at              DateTime             @default(now()) @db.Timestamptz(6)
  organization_profile    organization_profile @relation(fields: [organization_profile_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_report_organization")
  project                 project?             @relation(fields: [project_id], references: [id], onUpdate: NoAction, map: "fk_report_project")
}

enum user_role_enum {
  APP_USER
  VOLUNTEER
  ORGANIZATION
  ADMIN
}

enum user_status_enum {
  ACTIVE
  INACTIVE
  BLOCKED
  PENDING
}

enum project_status_enum {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum task_status_enum {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum task_difficulty_enum {
  EASY
  MEDIUM
  HARD
}

enum task_assignment_status_enum {
  ASSIGNED
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum fundraising_campaign_status_enum {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum points_transaction_type_enum {
  EARN
  SPEND
  BONUS
  PENALTY
  ADJUSTMENT
}

enum approval_request_type_enum {
  ORGANIZATION
  VOLUNTEER
  PROJECT
  NEWS
  FUNDRAISING
  OTHER
}

enum approval_request_status_enum {
  PENDING
  APPROVED
  REJECTED
}

enum verification_status_enum {
  PENDING
  VERIFIED
  REJECTED
}

enum ticket_status_enum {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
  CANCELLED
}

enum ticket_priority_enum {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum warning_status_enum {
  ACTIVE
  RESOLVED
  CANCELLED
}

enum warning_severity_enum {
  LOW
  MEDIUM
  HIGH
}

enum organization_membership_request_status_enum {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum organization_membership_request_direction_enum {
  REQUEST
  INVITE
}

enum report_type_enum {
  FINANCIAL
  RESULT
  ACTIVITY
  OTHER
}
