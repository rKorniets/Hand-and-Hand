{
  "name": "HandAndHand",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "start:backend": "cd backend/server && nest start --watch",
    "start:frontend": "cd frontend/app && ng serve -o",
    "start:dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "lint:frontend": "cd frontend/app && npm run lint",
    "lint:backend": "cd backend/server && npm run lint",
    "lint": "npm-run-all --continue-on-error lint:frontend lint:backend",
    "format": "prettier . --write",
    "check": "prettier . --check"
  },
  "dependencies": {
    "@angular/core": "^21.2.3",
    "@angular/forms": "^21.2.3",
    "@angular/router": "^21.2.3",
    "@azure/storage-queue": "^12.29.0",
    "@nestjs/jwt": "^11.0.2",
    "@prisma/client": "^7.7.0",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "jwt-decode": "^4.0.0",
    "nodemailer": "^8.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3"
  },
  "private": true
}
