# ==========================================
# DATABASE CONFIGURATION (Prisma)
# ==========================================
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:your_db_password@localhost:5432/hand_and_hand?schema=public"

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
JWT_ACCESS_SECRET="your_super_secret_jwt_key_here"
ACCESS_TOKEN_TTL="15m"

# ==========================================
# EMAIL SERVICE (Nodemailer / Gmail)
# ==========================================
MAIL_USER="your_project_email@gmail.com"
MAIL_PASSWORD="your_app_password_here"

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_URL=http://localhost:4200

# ==========================================
# CLOUDINARY (Image Storage)
# ==========================================
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# ==========================================
# AZURE & MONOBANK WEBHOOKS
# ==========================================
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your_account_name;AccountKey=your_account_key;EndpointSuffix=core.windows.net"
MONO_WEBHOOK_URL="https://your-azure-webhook-url.azurewebsites.net/api/monoWebhook"
ENABLE_MONO_POLLING=false